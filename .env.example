# ── AI Services ────────────────────────────────────────────────────────────────
# Groq (primary LLM — legal chat, DM scan, FIR draft)
# Get a free key: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (image analysis, deepfake detection, fallback LLM)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Maps ────────────────────────────────────────────────────────────────────────
# Google Maps (server-side geocoding + directions proxy)
# Enable: Maps JS API, Geocoding API, Directions API
# https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Maps key exposed to the browser (restrict by HTTP referrer)
VITE_GOOGLE_MAPS_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database (Supabase) ─────────────────────────────────────────────────────────
# https://supabase.com — Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Project Settings → Database → Connection String (replace [YOUR-PASSWORD])
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# Frontend Supabase vars (same values, prefixed for Vite)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Auth (Clerk) ───────────────────────────────────────────────────────────────
# https://clerk.com — enable Email + Google providers
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated allowed origins for Clerk JWT verification
CLERK_AUTHORIZED_PARTIES=https://your-app.vercel.app,http://localhost:5173

# ── Security ───────────────────────────────────────────────────────────────────
# Change this before going to production!
MODERATOR_BOOTSTRAP_KEY=change-me-in-production-use-long-random-string

# Comma-separated allowed CORS origins (leave blank to allow all in dev)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ── Optional: SMS Alerts ────────────────────────────────────────────────────────
# Twilio (server-side SOS SMS — app also works via device SMS link without this)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8787

# ── Frontend API URL ───────────────────────────────────────────────────────────
# Leave blank in production (Vercel serves /api/* from the same domain).
# Set to http://localhost:8787 only if frontend and backend run on different ports in dev.
VITE_API_URL=
