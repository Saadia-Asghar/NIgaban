GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Browser Maps JavaScript API (restrict by HTTP referrer to your dev + prod origins)
VITE_GOOGLE_MAPS_API_KEY=

# --- Google Agent Platform / Gemini / Stitch (optional) ---
# Gemini API key (AI Studio quickstart): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Some Google SDKs read this instead of GEMINI_API_KEY
GOOGLE_API_KEY=

# Stitch MCP (see .cursor/mcp.json): use API key OR run: npx @_davideast/stitch-mcp init
# Enable API in GCP: gcloud beta services mcp enable stitch.googleapis.com --project=YOUR_PROJECT_ID
STITCH_API_KEY=
GOOGLE_CLOUD_PROJECT=
# Optional: use your machine's gcloud Application Default Credentials
# STITCH_USE_SYSTEM_GCLOUD=1
# Project ref rotpzcptrkqltybeqdpf → https://rotpzcptrkqltybeqdpf.supabase.co
SUPABASE_URL=https://rotpzcptrkqltybeqdpf.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxx
# URL-encode special characters in password (e.g. # -> %23)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.rotpzcptrkqltybeqdpf.supabase.co:5432/postgres
VITE_SUPABASE_URL=https://rotpzcptrkqltybeqdpf.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxx
# Clerk: optional - Keyless mode auto-generates dev keys on first run (you'll see "Claim your app" popup).
# To use your own Clerk app, get the publishable key from dashboard.clerk.com -> API Keys
VITE_CLERK_PUBLISHABLE_KEY=
# Server: required for Clerk → Supabase DB user sync (POST /api/auth/clerk-sync)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: comma-separated front-end origins (e.g. http://localhost:5173,https://yourapp.com)
CLERK_AUTHORIZED_PARTIES=
MODERATOR_BOOTSTRAP_KEY=change-me-in-production
PORT=8787
